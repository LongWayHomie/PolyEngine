  <!-- ==================================================================
       Release|x64 outer build: four inner Rebuilds → stub_v0.bin .. stub_v3.bin
       (distinct IntDir + POLY_VARIANT).  No external scripts.
       When PolyInnerVariant is set, normal Cpp Build pipeline runs once.
       ================================================================== -->
  <Target Name="BuildAllLoaderVariants"
          Condition="'$(Configuration)|$(Platform)'=='Release|x64' and '$(PolyInnerVariant)'==''">
    <Message Importance="high" Text="[Stub] Building loader variants stub_v0.bin .. stub_v3.bin ..." />
    <MSBuild Projects="$(MSBuildProjectFullPath)"
             Targets="Rebuild"
             Properties="Configuration=Release;Platform=x64;PolyInnerVariant=0" />
    <MSBuild Projects="$(MSBuildProjectFullPath)"
             Targets="Rebuild"
             Properties="Configuration=Release;Platform=x64;PolyInnerVariant=1" />
    <MSBuild Projects="$(MSBuildProjectFullPath)"
             Targets="Rebuild"
             Properties="Configuration=Release;Platform=x64;PolyInnerVariant=2" />
    <MSBuild Projects="$(MSBuildProjectFullPath)"
             Targets="Rebuild"
             Properties="Configuration=Release;Platform=x64;PolyInnerVariant=3" />
    <Message Importance="high" Text="[Stub] All loader variants built → $(OutDir)stub_v*.bin" />
  </Target>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64' and '$(PolyInnerVariant)'==''">
    <BuildDependsOn>BuildAllLoaderVariants</BuildDependsOn>
    <RebuildDependsOn>BuildAllLoaderVariants</RebuildDependsOn>
  </PropertyGroup>
